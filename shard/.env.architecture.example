NODE_ENV=development
PORT=3000

# Authoritative durable database
DATABASE_URL=postgresql://wog:wog@127.0.0.1:5432/wog

# Redis is runtime/cache/queue only
REDIS_URL=redis://127.0.0.1:6379
REQUIRE_REDIS_PERSISTENCE=true

# Testnet-first chain mode
SHARD_CHAIN_ENV=testnet

# Existing app secrets/contracts can still live here
JWT_SECRET=replace-me
ENCRYPTION_KEY=replace-me
SERVER_PRIVATE_KEY=replace-me

PORT=3000
WOG_SHARD_URL=http://127.0.0.1:3000

# Select one preset: local | testnet | mainnet
SHARD_CHAIN_ENV=testnet

# Local-only convenience switch. When DEV=true and SHARD_CHAIN_ENV=local,
# shard prefers the active Hardhat deployment manifest.
DEV=false

JWT_SECRET=replace-me
ENCRYPTION_KEY=replace-me
SERVER_PRIVATE_KEY=0x...
THIRDWEB_SECRET_KEY=
REDIS_URL=redis://127.0.0.1:6379/15

# Optional overrides. Leave blank to use the selected preset values.
SKALE_BASE_RPC_URL=
SKALE_BASE_CHAIN_ID=
GOLD_CONTRACT_ADDRESS=
ITEMS_CONTRACT_ADDRESS=
CHARACTER_CONTRACT_ADDRESS=
IDENTITY_REGISTRY_ADDRESS=
REPUTATION_REGISTRY_ADDRESS=
VALIDATION_REGISTRY_ADDRESS=
AUCTION_HOUSE_CONTRACT_ADDRESS=
TRADE_CONTRACT_ADDRESS=
GUILD_CONTRACT_ADDRESS=
GUILD_VAULT_CONTRACT_ADDRESS=
LAND_REGISTRY_CONTRACT_ADDRESS=
NAME_SERVICE_CONTRACT_ADDRESS=
PREDICTION_CONTRACT_ADDRESS=

# ── MPP / Tempo Direct-Buy Marketplace ────────────────────────────────
MPP_SECRET_KEY=
MPP_RECIPIENT_ADDRESS=0x...
MPP_CURRENCY_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e
MPP_TESTNET=true

# ── NPC Dialogue Provider (OpenAI-compatible) ────────────────────────
NPC_DIALOGUE_API_BASE_URL=https://api.inference.net/v1
NPC_DIALOGUE_API_KEY=
NPC_DIALOGUE_MODEL=inference-net/schematron-3b
NPC_DIALOGUE_TEMPERATURE=0.2
NPC_DIALOGUE_TIMEOUT_MS=12000

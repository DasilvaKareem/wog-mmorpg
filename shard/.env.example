# ── MPP / Tempo Direct-Buy Marketplace ────────────────────────────────
# Generate: openssl rand -hex 32
MPP_SECRET_KEY=

# Your treasury/recipient wallet address (receives sale proceeds)
# Get via: tempo wallet
MPP_RECIPIENT_ADDRESS=0x...

# ERC-20 token contract for payment currency (e.g. USDC)
# Base Sepolia testnet USDC: 0x036CbD53842c5426634e7929541eC2318f3dCF7e
# Base mainnet USDC:         0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
MPP_CURRENCY_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# Set to "false" for production
MPP_TESTNET=true
